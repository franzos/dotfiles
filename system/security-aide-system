#!/usr/bin/env bash
# security-aide-system — daily AIDE check for system-scope paths
#
# Runs AIDE as root against /etc/aide/aide.conf, commits the DB to a local
# git repo for tamper-evidence, and appends any diff to the log. No email.

set -euo pipefail
umask 077

CONF="$AIDE_CONF"
STATE="/var/lib/aide"
DB="$STATE/aide.db"
NEWDB="$STATE/aide.db.new"
LOG="/var/log/security-aide.log"

mkdir -p "$STATE"
chmod 700 "$STATE"
touch "$LOG"; chmod 600 "$LOG"

log() {
    printf '[%s] %s\n' "$(date -Iseconds)" "$*" >> "$LOG"
}

host=$(uname -n)

if [[ ! -f "$CONF" ]]; then
    log "ERROR: config $CONF not found"
    exit 1
fi

# Ensure git repo exists in state dir
if [[ ! -d "$STATE/.git" ]]; then
    git -C "$STATE" init -q -b main
    git -C "$STATE" config user.name  "security-aide-system"
    git -C "$STATE" config user.email "root@$host"
    log "initialized git repo at $STATE"
fi

# -----------------------------------------------------------------------------
# First run: build baseline
# -----------------------------------------------------------------------------
if [[ ! -f "$DB" ]]; then
    log "no baseline found — initializing"
    aide --init --config="$CONF" < /dev/null >> "$LOG" 2>&1
    if [[ ! -f "$NEWDB" ]]; then
        log "ERROR: aide --init did not produce $NEWDB"
        exit 1
    fi
    mv "$NEWDB" "$DB"
    git -C "$STATE" add -A
    git -C "$STATE" commit -q -m "init: baseline $(date -Iseconds) on $host"
    log "baseline committed"
    exit 0
fi

# -----------------------------------------------------------------------------
# Check run
# -----------------------------------------------------------------------------
log "starting aide check"
TMPOUT=$(mktemp)
trap 'rm -f "$TMPOUT"' EXIT

set +e
aide --check --config="$CONF" < /dev/null > "$TMPOUT" 2>&1
rc=$?
set -e

# AIDE --check exit codes:
#   0          = no differences
#   1          = new files detected
#   2          = removed files detected
#   4          = changed files detected
#   1..7       = bitwise combinations of the above
#   >=8        = error conditions (14=write err, 15=invalid arg, 18=IO err, ...)
if [[ $rc -eq 0 ]]; then
    log "clean"
    exit 0
fi

if [[ $rc -ge 8 ]]; then
    log "ERROR: aide --check returned $rc"
    {
        printf '=== %s ERROR rc=%s ===\n' "$(date -Iseconds)" "$rc"
        cat "$TMPOUT"
        printf '\n'
    } >> "$LOG"
    exit 1
fi

# Derive what kinds of changes occurred from AIDE's exit-code bitmask:
#   bit 0 (1) = new files
#   bit 1 (2) = removed files
#   bit 2 (4) = changed files
parts=()
if (( rc & 1 )); then parts+=("added"); fi
if (( rc & 2 )); then parts+=("removed"); fi
if (( rc & 4 )); then parts+=("changed"); fi
desc=$(IFS='/'; echo "${parts[*]}")

# Log full diff for audit trail. IMPORTANT: the baseline is NOT auto-updated.
# After reviewing this diff and confirming the changes are legitimate, run
# `security-aide-accept` to bake the current state in as the new baseline.
# Until you do, every subsequent run re-reports the same diff.
{
    printf '=== %s rc=%s kinds=%s ===\n' "$(date -Iseconds)" "$rc" "$desc"
    printf 'AIDE detected filesystem changes on %s.\n' "$host"
    printf 'baseline NOT updated; run security-aide-accept once reviewed.\n\n'
    cat "$TMPOUT"
    printf '\n'
} >> "$LOG"

log "logged diff ($desc)"

# Do NOT auto-update the baseline. User must explicitly accept.
exit 0
