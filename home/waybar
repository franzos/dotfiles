{
    "position": "top",
    "height": 16,
    "spacing": 4,
    "modules-left": ["sway/workspaces", "sway/mode", "sway/scratchpad", "custom/media"],
    "modules-center": ["sway/window"],
    "modules-right": ["cpu", "idle_inhibitor", "pulseaudio", "custom/bt-profile", "bluetooth", "network",  "backlight", "battery", "custom/power-profile", "clock", "clock#gmt1", "custom/gpg", "tray"],
    "sway/mode": {
        "format": "<span style=\"italic\">{}</span>"
    },
    "sway/scratchpad": {
        "format": "{icon} {count}",
        "show-empty": false,
        "format-icons": ["", "´őĺ"],
        "tooltip": true,
        "tooltip-format": "{app}: {title}"
    },
    "idle_inhibitor": {
        "format": "{icon}",
        "format-icons": {
            "activated": "´ü«",
            "deactivated": "´ü░"
        }
    },
    "tray": {
        "spacing": 10
    },
    "clock": {
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
        "format-alt": "{:%Y-%m-%d}"
    },
    "clock#gmt1": {
        "timezone": "Europe/Paris",
        "format": "{:%H:%M}",
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>\nGMT+1 Time",
        "format-alt": "{:%Y-%m-%d %H:%M %Z}"
    },
    "cpu": {
        "format": "{usage}% ´őŤ",
        "tooltip": false,
        "interval": 5,
        "states": {
            "warning": 70,
            "critical": 90
        },
        "on-click": "footclient -e htop"
    },
    "memory": {
        "format": "{}% ´âë"
    },
    "temperature": {
        "critical-threshold": 80,
        "format": "{temperatureC}┬░C {icon}",
        "format-icons": ["´Łź", "´őë", "´Łę"]
    },
    "backlight": {
        "format": "{percent}% {icon}",
        "format-icons": ["ţÄŹ", "ţĆô", "ţĆĹ", "ţĆĆ", "ţĆÄ", "ţĆŹ", "ţĆŐ", "ţĆł", "ţÄŤ"]
    },
    "battery": {
        "states": {
            "warning": 30,
            "critical": 15
        },
        "format": "{capacity}% {icon}",
        "format-charging": "{capacity}% ´Śž",
        "format-plugged": "{capacity}% ´çŽ",
        "format-alt": "{time} {icon}",
        "format-icons": ["´ëä", "´ëâ", "´ëé", "´ëü", "´ëÇ"]
    },
    "network": {
        "format-wifi": "{essid} ({signalStrength}%) ´çź",
        "format-ethernet": "{ipaddr}/{cidr} ´×ľ",
        "tooltip-format": "{ifname} via {gwaddr} ´×ľ",
        "format-linked": "{ifname} (No IP) ´×ľ",
        "format-disconnected": "Disconnected ÔÜá",
        "format-alt": "{ifname}: {ipaddr}/{cidr}"
    },
    "pulseaudio": {
        "format": "{volume}% {icon} {format_source}",
        "format-bluetooth": "{volume}% {icon}´Őö {format_source}",
        "format-bluetooth-muted": "´Üę {icon}´Őö {format_source}",
        "format-muted": "´Üę {format_source}",
        "format-source": "{volume}% ´ä░",
        "format-source-muted": "´ä▒",
        "format-icons": {
            "headphone": "´Çą",
            "hands-free": "´ľÉ",
            "headset": "´ľÉ",
            "phone": "´éĽ",
            "portable": "´éĽ",
            "car": "´ć╣",
            "default": ["´ÇŽ", "´Çž", "´ÇĘ"]
        },
        "on-click": "pavucontrol"
    },
    "bluetooth": {
        "format": "{icon}",
        "format-disabled": "",
        "format-off": "",
        "format-on": "",
        "format-connected": "{icon} {num_connections}",
        "format-connected-battery": "{icon} {device_alias} {device_battery_percentage}%",
        "format-icons": {
            "enabled": "",
            "disabled": ""
        },
        "tooltip-format": "{controller_alias}\t{status}\n{num_connections} connected",
        "tooltip-format-connected": "{controller_alias}\t{status}\n{num_connections} connected\n\n{device_enumerate}",
        "tooltip-format-enumerate-connected": "{device_alias}\t{device_address}",
        "tooltip-format-enumerate-connected-battery": "{device_alias}\t{device_battery_percentage}%",
        "on-click": "footclient -e bluetuith"
    },
    "custom/bt-profile": {
        "format": "{}",
        "return-type": "json",
        "interval": 3,
        "exec": "$HOME/.local/bin/bt-profile-status",
        "on-click": "$HOME/.local/bin/bt-toggle-profile",
        "tooltip": true
    },
    "custom/power-profile": {
        "format": "{}",
        "return-type": "json",
        "interval": 5,
        "exec": "$HOME/.local/bin/power-profile-status",
        "on-click": "$HOME/.local/bin/power-profile-toggle",
        "tooltip": true
    },
    "custom/gpg": {
        "format": "",
        "tooltip": true,
        "tooltip-format": "Click to reload Yubikey",
        "on-click": "gpg-connect-agent 'scd serialno' 'learn --force' /bye && notify-send 'GPG' 'Yubikey reloaded'"
    },
    "custom/media": {
        "format": "{icon} {}",
        "return-type": "json",
        "max-length": 40,
        "format-icons": {
            "spotify": "´ć╝",
            "default": "­čÄť"
        },
        "escape": true,
        "exec": "$HOME/.config/waybar/mediaplayer.py 2> /dev/null"
    }
}
