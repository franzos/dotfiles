#!/usr/bin/env bash
# Switch dunst notification daemon to dark (Fleet Dark Purple) theme

set -euo pipefail

CONFIG="$HOME/.config/dunst/dunstrc"

# Update colors for dark theme (Fleet Dark Purple)
sed -i 's/^    background = .*/    background = "#1C1827"/' "$CONFIG"
sed -i 's/^    foreground = .*/    foreground = "#E0E1E4"/' "$CONFIG"
sed -i 's/^    frame_color = .*/    frame_color = "#3E3852"/' "$CONFIG"
sed -i '/\[urgency_low\]/,/\[urgency_normal\]/ s/background = .*/background = "#1C1827"/' "$CONFIG"
sed -i '/\[urgency_low\]/,/\[urgency_normal\]/ s/foreground = .*/foreground = "#8E8FA2"/' "$CONFIG"
sed -i '/\[urgency_normal\]/,/\[urgency_critical\]/ s/background = .*/background = "#1C1827"/' "$CONFIG"
sed -i '/\[urgency_normal\]/,/\[urgency_critical\]/ s/foreground = .*/foreground = "#E0E1E4"/' "$CONFIG"
sed -i '/\[urgency_critical\]/,$ s/background = .*/background = "#432132"/' "$CONFIG"
sed -i '/\[urgency_critical\]/,$ s/foreground = .*/foreground = "#E1465E"/' "$CONFIG"
sed -i '/\[urgency_critical\]/,$ s/frame_color = .*/frame_color = "#6b2a3d"/' "$CONFIG"

# Restart dunst to apply changes (backgrounded to avoid signal propagation issues with darkman)
(killall dunst 2>/dev/null || true) &
exit 0
